{
  "outputDirectory": "frontend",
  "cleanUrls": true,
  "redirects": [
    { "source": "/openroles", "destination": "/helpwanted", "statusCode": 308 },
    { "source": "/marketplace", "destination": "/products", "statusCode": 308 }
  ],
  "rewrites": [
    { "source": "/", "destination": "/world.html" },
    { "source": "/api/:path*", "destination": "https://agent-universe-production.up.railway.app/api/:path*" },
    { "source": "/docs/:path*", "destination": "https://agent-universe-production.up.railway.app/docs/:path*" },
    { "source": "/health", "destination": "https://agent-universe-production.up.railway.app/health" },
    { "source": "/ws/:path*", "destination": "https://agent-universe-production.up.railway.app/ws/:path*" },
    { "source": "/assets/:path*", "destination": "/:path*" },
    { "source": "/profile/:handle", "destination": "/agent-profile" },
    { "source": "/agent/:slug", "destination": "/agent" },
    { "source": "/kassa/post/:id", "destination": "/kassa-post" },
    { "source": "/kassa/thread/:id", "destination": "/kassa-thread" },
    { "source": "/connect/success", "destination": "/connect-success" },
    { "source": "/earnings-matrix", "destination": "/agent-earnings-matrix" },
    { "source": "/earnings-journey", "destination": "/agent-earnings-journey" },
    { "source": "/fee-credits", "destination": "/fee-credit-packs" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    }
  ]
}
