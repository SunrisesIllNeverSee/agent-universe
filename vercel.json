{
  "outputDirectory": "frontend",
  "cleanUrls": true,
  "redirects": [
    {
      "source": "/openroles",
      "destination": "/helpwanted",
      "statusCode": 308
    },
    {
      "source": "/marketplace",
      "destination": "/products",
      "statusCode": 308
    },
    {
      "source": "/3d",
      "destination": "/world",
      "statusCode": 308
    },
    {
      "source": "/economy",
      "destination": "/economics",
      "statusCode": 308
    },
    {
      "source": "/civitae-roadmap",
      "destination": "/portal",
      "statusCode": 308
    }
  ],
  "rewrites": [
    {
      "source": "/.well-known/agent.json",
      "destination": "/agent.json"
    },
    {
      "source": "/.well-known/mcp-server-card.json",
      "destination": "https://agent-universe-production.up.railway.app/.well-known/mcp-server-card.json"
    },
    {
      "source": "/",
      "destination": "/kingdoms.html"
    },
    {
      "source": "/portal",
      "destination": "/portal.html"
    },
    {
      "source": "/moses",
      "destination": "/moses.html"
    },
    {
      "source": "/join",
      "destination": "/join.html"
    },
    {
      "source": "/lobby",
      "destination": "/lobby.html"
    },
    {
      "source": "/api/:path*",
      "destination": "https://agent-universe-production.up.railway.app/api/:path*"
    },
    {
      "source": "/docs/:path*",
      "destination": "https://agent-universe-production.up.railway.app/docs/:path*"
    },
    {
      "source": "/health",
      "destination": "https://agent-universe-production.up.railway.app/health"
    },
    {
      "source": "/ws/:path*",
      "destination": "https://agent-universe-production.up.railway.app/ws/:path*"
    },
    {
      "source": "/assets/:path*",
      "destination": "/:path*"
    },
    {
      "source": "/profile/:handle",
      "destination": "/agent-profile"
    },
    {
      "source": "/agent/:slug",
      "destination": "/agent"
    },
    {
      "source": "/kassa/post/:id",
      "destination": "/kassa-post"
    },
    {
      "source": "/kassa/thread/:id",
      "destination": "/kassa-thread"
    },
    {
      "source": "/connect/success",
      "destination": "/connect-success"
    },
    {
      "source": "/earnings-matrix",
      "destination": "/agent-earnings-matrix"
    },
    {
      "source": "/earnings-journey",
      "destination": "/agent-earnings-journey"
    },
    {
      "source": "/fee-credits",
      "destination": "/fee-credit-packs"
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*).js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=300, must-revalidate"
        }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400, stale-while-revalidate=3600"
        }
      ]
    },
    {
      "source": "/(.*).html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600, must-revalidate"
        }
      ]
    },
    {
      "source": "/pages.json",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=300, must-revalidate"
        }
      ]
    },
    {
      "source": "/favicon.ico",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=604800"
        }
      ]
    },
    {
      "source": "/(llms.txt|agent.json|robots.txt|skill.md)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600, must-revalidate"
        },
        {
          "key": "X-Robots-Tag",
          "value": "noarchive"
        }
      ]
    },
    {
      "source": "/.well-known/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600, must-revalidate"
        },
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        }
      ]
    }
  ],
  "experimentalServices": {
    "web": {
      "routePrefix": "/"
    }
  }
}
