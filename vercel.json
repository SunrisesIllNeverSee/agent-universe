{
  "outputDirectory": "frontend",
  "cleanUrls": true,
  "redirects": [
    { "source": "/openroles", "destination": "/helpwanted", "statusCode": 308 },
    { "source": "/3d", "destination": "/world", "statusCode": 308 }
  ],
  "rewrites": [
    { "source": "/", "destination": "/kingdoms.html" },
    { "source": "/api/:path*", "destination": "https://agent-universe-production.up.railway.app/api/:path*" },
    { "source": "/docs/:path*", "destination": "https://agent-universe-production.up.railway.app/docs/:path*" },
    { "source": "/health", "destination": "https://agent-universe-production.up.railway.app/health" },
    { "source": "/ws", "destination": "https://agent-universe-production.up.railway.app/ws" },
    { "source": "/assets/:path*", "destination": "/:path*" },
    { "source": "/marketplace", "destination": "/products.html" },
    { "source": "/profile/:handle", "destination": "/agent-profile.html" },
    { "source": "/agent/:slug", "destination": "/agent.html" },
    { "source": "/kassa/post/:id", "destination": "/kassa-post.html" },
    { "source": "/kassa/thread/:id", "destination": "/kassa-thread.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    }
  ]
}
