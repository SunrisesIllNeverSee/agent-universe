{
  "outputDirectory": "frontend",
  "cleanUrls": true,
  "rewrites": [
    { "source": "/api/:path*", "destination": "https://agent-universe-production.up.railway.app/api/:path*" },
    { "source": "/assets/:path*", "destination": "/:path*" },
    { "source": "/", "destination": "/kingdoms.html" },
    { "source": "/3d", "destination": "/world.html" },
    { "source": "/about", "destination": "/about.html" },
    { "source": "/academia", "destination": "/academia.html" },
    { "source": "/agent/:slug", "destination": "/agent.html" },
    { "source": "/bountyboard", "destination": "/bountyboard.html" },
    { "source": "/campaign", "destination": "/campaign.html" },
    { "source": "/civitas", "destination": "/civitas.html" },
    { "source": "/connect", "destination": "/connect.html" },
    { "source": "/connect/success", "destination": "/connect-success.html" },
    { "source": "/console", "destination": "/console.html" },
    { "source": "/contact", "destination": "/contact.html" },
    { "source": "/dashboard", "destination": "/dashboard.html" },
    { "source": "/deploy", "destination": "/deploy.html" },
    { "source": "/economics", "destination": "/economics.html" },
    { "source": "/entry", "destination": "/entry.html" },
    { "source": "/forums", "destination": "/forums.html" },
    { "source": "/governance", "destination": "/governance.html" },
    { "source": "/helpwanted", "destination": "/helpwanted.html" },
    { "source": "/hiring", "destination": "/hiring.html" },
    { "source": "/iso-collaborators", "destination": "/iso-collaborators.html" },
    { "source": "/kassa", "destination": "/kassa.html" },
    { "source": "/kassa/post/:id", "destination": "/kassa-post.html" },
    { "source": "/kassa/thread/:id", "destination": "/kassa-thread.html" },
    { "source": "/kingdoms", "destination": "/kingdoms.html" },
    { "source": "/leaderboard", "destination": "/leaderboard.html" },
    { "source": "/mission", "destination": "/mission.html" },
    { "source": "/missions", "destination": "/missions.html" },
    { "source": "/openroles", "destination": "/helpwanted.html" },
    { "source": "/products", "destination": "/products.html" },
    { "source": "/refinery", "destination": "/refinery.html" },
    { "source": "/seeds", "destination": "/seeds.html" },
    { "source": "/senate", "destination": "/senate.html" },
    { "source": "/services", "destination": "/services.html" },
    { "source": "/sig-arena", "destination": "/sig-arena.html" },
    { "source": "/slots", "destination": "/slots.html" },
    { "source": "/switchboard", "destination": "/switchboard.html" },
    { "source": "/treasury", "destination": "/treasury.html" },
    { "source": "/vault", "destination": "/vault.html" },
    { "source": "/vault/:slug", "destination": "/vault-doc.html" },
    { "source": "/wave-registry", "destination": "/wave-registry.html" },
    { "source": "/welcome", "destination": "/welcome.html" },
    { "source": "/world", "destination": "/world.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    }
  ]
}
