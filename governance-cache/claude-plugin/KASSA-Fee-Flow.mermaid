---
title: "KA§§A Fee Flow — How Money Moves"
---

%%{init: {'theme': 'dark', 'themeVariables': { 'primaryColor': '#C4923A', 'primaryTextColor': '#fff', 'primaryBorderColor': '#C4923A', 'lineColor': '#6a6a8a', 'secondaryColor': '#1e1e2a', 'tertiaryColor': '#111118', 'fontFamily': 'monospace'}}}%%

flowchart TB
    BUILDER["Agent Builder<br/>Creates governed agent config<br/>+ MO§E§™ governance profile"]
    
    BUILDER -->|"Lists agent on KA§§A<br/>via Bags Launch API"| LAUNCH["Token Launch<br/>Agent becomes a Bags token<br/>with governance metadata"]

    LAUNCH -->|"Token goes live"| MARKET["Open Market<br/>Anyone can buy/sell<br/>the agent token"]

    BUYER1["Founding Seat Buyer<br/>First 17 · Lowest price<br/>Bonding curve advantage"] -->|"Buys early"| MARKET
    
    BUYER2["Later Buyer<br/>Higher price<br/>Wave cascade in effect"] -->|"Buys later"| MARKET

    MARKET -->|"Every trade generates fees"| FEES{"Fee Split"}

    FEES -->|"1% of volume<br/>FOREVER"| CREATOR_CUT["Agent Builder<br/>Perpetual creator revenue"]
    
    FEES -->|"Partner fee"| KASSA_CUT["KA§§A Platform<br/>Ello Cello LLC revenue"]
    
    FEES -->|"Trading fee"| BAGS_CUT["Bags Protocol<br/>Platform revenue"]

    MARKET -->|"Token in wallet"| ACCESS{"Token = Access"}

    ACCESS -->|"Wallet connects<br/>to COMMAND"| COMMAND["COMMAND Console<br/>Governance config unlocks<br/>based on token tier"]

    ACCESS -->|"Can resell token<br/>at market price"| RESELL["Secondary Market<br/>Founding seats appreciate<br/>as demand grows"]

    RESELL -->|"Resale generates<br/>more trades"| FEES

    COMMAND -->|"Operates governed agent<br/>audit trail generated"| GOVERNED["Governed Agent Operation<br/>Every action under<br/>constitutional control"]

    GOVERNED -->|"Session hash"| ANCHOR["Onchain Audit Anchor<br/>Solana memo transaction<br/>Immutable proof"]

    subgraph REVENUE["REVENUE STREAMS"]
        direction LR
        CREATOR_CUT
        KASSA_CUT
    end

    subgraph VALUE_LOOP["VALUE LOOP"]
        direction LR
        RESELL
        FEES
    end

