graph TB
    subgraph L4["LAYER 4 — CLAUDE MARKETPLACE"]
        direction LR
        MP_ENTRY["Partner Waitlist<br/>claude.com/marketplace-partners"]
        MP_PRODUCT["COMMAND on Marketplace<br/>Enterprise customers buy with<br/>existing Anthropic commitment"]
        MP_PEERS["Sits alongside:<br/>GitLab · Harvey · Rogo<br/>Snowflake · Replit · Lovable"]
        MP_REVENUE["Revenue<br/>Anthropic handles billing<br/>No commission"]
        MP_ENTRY --> MP_PRODUCT
        MP_PRODUCT --- MP_PEERS
        MP_PRODUCT --> MP_REVENUE
    end

    subgraph L3["LAYER 3 — CLAUDE CODE PLUGIN DIRECTORY"]
        direction LR
        PL_ENTRY["Plugin Submission<br/>clau.de/plugin-directory-submission"]
        PL_PRODUCT["MO§E§™ Plugin<br/>8 slash commands · 5 skills<br/>3 agents · hooks · docs"]
        PL_USERS["Every Claude Code<br/>developer can install<br/>/plugin install moses-governance"]
        PL_ENTRY --> PL_PRODUCT --> PL_USERS
    end

    subgraph L2["LAYER 2 — BAGS HACKATHON"]
        direction LR
        BG_ENTRY["Application<br/>bags.fm/hackathon"]
        BG_PRODUCT["KA§§A Marketplace<br/>Governed agents as tokens<br/>Fee sharing · Founding seats"]
        BG_PROOF["Onchain Proof<br/>Tokens traded · Fees earned<br/>Agents governed · Audits anchored"]
        BG_ENTRY --> BG_PRODUCT --> BG_PROOF
    end

    subgraph L1["LAYER 1 — CLAUDE SKILL (ENGINE)"]
        direction LR
        SK_GOV["governance.py<br/>Mode translation<br/>Context assembly"]
        SK_AUDIT["audit.py<br/>SHA-256 chain<br/>Tamper-evident ledger"]
        SK_SKILL["SKILL.md<br/>Auto-activating<br/>governance enforcement"]
        SK_GOV --- SK_AUDIT --- SK_SKILL
    end

    subgraph IP["IP FOUNDATION (UNCOPYABLE)"]
        direction LR
        PATENT["Patent<br/>PPA4<br/>Serial No. 63/877,177"]
        PAPER["Peer-Reviewed Paper<br/>Independent validation<br/>ABBA · Imperial College"]
        FRAMEWORK["MO§E§™ Framework<br/>Constitutional governance<br/>Mathematical formalism"]
        PATENT --- PAPER --- FRAMEWORK
    end

    %% How layers feed each other
    L1 -->|"Powers"| L2
    L2 -->|"Proves traction for"| L3
    L3 -->|"Creates demand for"| L4
    L4 -->|"Enterprise revenue<br/>funds growth of"| L2

    %% IP feeds everything
    IP -.->|"Protects"| L1
    IP -.->|"Protects"| L2
    IP -.->|"Protects"| L3
    IP -.->|"Protects"| L4

    subgraph DEPLOY["DEPLOY — CROSS-CHAIN EXECUTION"]
        direction LR
        DP_MCP["MCP Governance API<br/>~200 lines · The bridge<br/>Chain-agnostic engine"]
        DP_T1["Tier 1 — Fastest<br/>Virtuals (Base) · 15K+ agents<br/>Bags (Solana) · ElizaOS"]
        DP_T2["Tier 2 — High Value<br/>Fetch.ai (Cosmos) · 50K+ agents<br/>Autonolas · Claude Marketplace"]
        DP_T3["Tier 3 — Infrastructure<br/>Bittensor · Render · The Graph<br/>ML · GPU · Data indexing"]
        DP_MANIFEST["Deploy Manifest<br/>~30 lines YAML per target<br/>Chain · Token · Pricing · Gas"]
        DP_ADAPTERS["Thin Adapters<br/>~150 lines each<br/>Same governance, different runway"]
        DP_MCP --> DP_ADAPTERS
        DP_ADAPTERS --> DP_T1
        DP_ADAPTERS --> DP_T2
        DP_ADAPTERS --> DP_T3
        DP_MANIFEST --> DP_ADAPTERS
    end

    subgraph INSTALL["INSTALL — DISTRIBUTION CHANNELS"]
        direction LR
        IN_WEB["claude.ai (Web)<br/>Memory edits<br/>Already active"]
        IN_CLI["Claude Code CLI<br/>CLAUDE.md + Plugin<br/>~/.claude/plugins/"]
        IN_DESK["Cowork (Desktop)<br/>Global Instructions<br/>+ memory.md"]
        IN_CMD["/plugin install<br/>moses-governance"]
        IN_CMD --> IN_CLI
        IN_WEB --- IN_CLI --- IN_DESK
    end

    %% Deploy connects to layers
    DEPLOY -->|"Adapters deploy<br/>governed agents to"| L2
    DEPLOY -->|"MCP native adapter<br/>already built"| L4
    L1 -->|"Engine powers"| DEPLOY

    %% Install feeds awareness
    INSTALL -->|"Users discover via"| L3

    %% The product
    COMMAND["COMMAND<br/>mos2es.io<br/>The cockpit behind<br/>all four doors + DEPLOY"]
    COMMAND -.-> L1
    COMMAND -.-> L2
    COMMAND -.-> L3
    COMMAND -.-> L4
    COMMAND -.-> DEPLOY

